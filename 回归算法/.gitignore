# 回归算法项目 .gitignore
# 覆盖根目录的 .gitignore 规则

# 不忽略数据和模型文件
!data/
!models/

# 忽略其他不必要的文件
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# 虚拟环境
.env/
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# IDE 配置
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# 系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# 测试缓存
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# 类型检查器和代码检查
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json
.pytype/

# 日志文件
*.log
*.tmp
*.temp
*.bak
*.orig
.cache/
tmp/
temp/
scratch/
